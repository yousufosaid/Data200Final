      "source": [
        "#define response variable\n",
        "y_per = player_stats['PER']\n",
        "\n",
        "#We will use all the basic variables from our player_basic data set\n",
        "basic_stats_cols = [\n",
        "    'G', 'GS', 'MP', 'FG', 'FGA', 'FG%', '3P', '3PA', '3P%', '2P', '2PA', '2P%',\n",
        "    'eFG%', 'FT', 'FTA', 'FT%', 'ORB', 'DRB', 'TRB', 'AST', 'STL', 'BLK', 'TOV', 'PF', 'PTS'\n",
        "]\n",
        "X_basic_stats = player_stats[basic_stats_cols]\n",
        "\n",
        "print(f\"Shape of y_per: {y_per.shape}\")\n",
        "print(f\"Shape of X_basic_stats: {X_basic_stats.shape}\")\n",
        "display(X_basic_stats.head())"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "Wz0biiTOkxaP"
      },
      "source": [
        "We can start by fitting a linear regression model using all basic variables as the predictors."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 40,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "eKAsAxxjkeD5",
        "outputId": "a53dcff4-ae09-4a6b-e7e7-fd4a9c2ac2f7"
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "X_train_per shape: (588, 25)\n",
            "X_test_per shape: (148, 25)\n",
            "y_train_per shape: (588,)\n",
            "y_test_per shape: (148,)\n",
            "Mean Squared Error (MSE): 10.50\n",
            "R-squared (R2): 0.72\n"
          ]
        }
      ],
      "source": [
        "# Split the data into training and testing sets using 80/20 split\n",
        "X_train_per, X_test_per, y_train_per, y_test_per = train_test_split(X_basic_stats, y_per, test_size=0.2, random_state=11)\n",
        "\n",
        "print(f\"X_train_per shape: {X_train_per.shape}\")\n",
        "print(f\"X_test_per shape: {X_test_per.shape}\")\n",
        "print(f\"y_train_per shape: {y_train_per.shape}\")\n",
        "print(f\"y_test_per shape: {y_test_per.shape}\")\n",
        "\n",
        "# Initialize and train the Linear Regression model\n",
        "per_model = LinearRegression()\n",
        "per_model.fit(X_train_per, y_train_per)\n",
        "\n",
        "# Make predictions on the test set\n",
        "y_pred_per = per_model.predict(X_test_per)\n",
        "\n",
        "#evaluate model\n",
        "mse = mean_squared_error(y_test_per, y_pred_per)\n",
        "R2 = r2_score(y_test_per, y_pred_per)\n",
        "\n",
        "print(f\"Mean Squared Error (MSE): {mse:.2f}\")\n",
        "print(f\"R-squared (R2): {R2:.2f}\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "BNaEE-tQlR-Z"
      },
      "source": [

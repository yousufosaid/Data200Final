      "source": [
        "# Fill missing numerical values in numeric columns with the mean of their columns\n",
        "numerical_cols = player_stats.select_dtypes(include=['number']).columns.tolist()\n",
        "for col in numerical_cols:\n",
        "    if player_stats[col].isnull().any():\n",
        "        player_stats[col].fillna(player_stats[col].mean(), inplace=True)\n",
        "\n",
        "print('Updated missing values:')\n",
        "print(player_stats.isnull().sum()[player_stats.isnull().sum() > 0])"
      ]
